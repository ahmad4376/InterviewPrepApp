{
  "name": "interview-prep-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css,scss,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,css,scss,yaml,yml}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,md,css,scss,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@clerk/nextjs": "^6.37.3",
    "@deepgram/sdk": "^4.7.0",
    "@lottiefiles/react-lottie-player": "^3.6.0",
    "@monaco-editor/react": "^4.7.0",
    "@react-hook/resize-observer": "^2.0.2",
    "@types/pdfkit": "^0.17.4",
    "@uidotdev/usehooks": "^2.4.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "mongoose": "^9.3.0",
    "next": "^15.5.12",
    "openai": "^6.29.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.18.0",
    "react": "^19",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19",
    "sass": "^1.98.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8.57.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8",
    "eslint-config-next": "^15",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
