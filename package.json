    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.563.0",
    "mammoth": "^1.12.0",
    "mongoose": "^9.4.1",
    "next": "^15.5.12",
    "next-themes": "^0.4.6",
