    "@uidotdev/usehooks": "^2.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "mammoth": "^1.11.0",
    "mongoose": "^9.1.6",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "openai": "^6.18.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "react": "^19",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19",
