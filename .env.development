# Shared development environment config for Next.js
# API keys are NOT stored here — create .env.local with real values.
# Ask a team member for the shared dev keys, then:
#   cp .env.example .env.local
#   # Fill in the real key values

# Clerk Authentication (test/dev)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# MongoDB Atlas (dev database)
MONGO_URL=

# Deepgram Voice Agent
DEEPGRAM_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Piston Code Execution API
PISTON_API_URL=

# LeetCode Premium (fetcher script only — not needed at runtime)
LEETCODE_SESSION=
LEETCODE_CSRF_TOKEN=
